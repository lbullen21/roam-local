ANTHROPIC_API_KEY=your_key_here

# Optional. Enables real photos of actual restaurants and lesser-known spots
# via Google Places. Outdoor spots fall back to Wikipedia (no key needed).
# Without this key, cards without a Wikipedia match show a gradient placeholder
# rather than a misleading stock photo.
# Setup: https://developers.google.com/maps/documentation/places/web-service/get-api-key
GOOGLE_PLACES_API_KEY=
